# internal IPs. Never commit them.
*.log
logs/

# ── Generated reports / run artifacts ────────────────────────────────────────
reports/
*.html.out

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# ── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
